{
  "description": "Hyperparameter search space for CellposeSAM nuclei finetuning.",
  "base_config": "configs/finetune_nuclei_config.json",
  "search": {
    "n_epochs": [50, 100, 200],
    "learning_rate": [1e-5, 1e-4, 5e-4],
    "weight_decay": [1e-5, 1e-4, 1e-3],
    "freeze_encoder": [true, false],
    "batch_size": [8]
  },
  "output": {
    "results_dir": "results/hparam_search",
    "results_json": "results/hparam_search/results.json"
  },
  "primary_metric": "3d_ap_0.75",
  "comment": "n_epochs/freeze_encoder combos with unfreeze use a lower max LR guard via max_lr_unfrozen."
}
